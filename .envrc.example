# Required
export OPENWEATHERMAP_KEY="your_api_key_here"
export LATITUDE="52.3508"
export LONGITUDE="5.2647"
export LOCATION_NAME="Almere"

# Optional (defaults shown)
export UNITS="metric"
export LANG="en"
export DISPLAY_VIEWS="weather"           # comma-separated: "weather,wikipedia,tasks"
export REFRESH_INTERVAL="900"
# export PREVIEW_MODE="true"  # Force preview mode even on Pi

# CalDAV (required for "tasks" view — works with Nextcloud, Radicale, etc.)
# export CALDAV_URL="https://cloud.example.com"
# export CALDAV_USERNAME="your_username"
# export CALDAV_PASSWORD="your_app_password"
# export CALDAV_TASK_LISTS=""  # comma-separated list names; empty = all
