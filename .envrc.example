# Display (defaults shown)
export DISPLAY_VIEWS="system"           # comma-separated list of view names
export REFRESH_INTERVAL="900"
# export PREVIEW_MODE="true"  # Force preview mode even on Pi

# Weather (required for "weather" view)
# export OPENWEATHERMAP_KEY="your_api_key_here"  # https://openweathermap.org/api
# export LATITUDE="52.3508"
# export LONGITUDE="5.2647"
# export LOCATION_NAME="Almere"
# export UNITS="metric"  # metric / imperial / standard
# export LANG="en"
# export PREVIEW_MODE="true"  # Force preview mode even on Pi

# CalDAV (required for "tasks" view — works with Nextcloud, Radicale, etc.)
# export CALDAV_URL="https://cloud.example.com"
# export CALDAV_USERNAME="your_username"
# export CALDAV_PASSWORD="your_app_password"
# export CALDAV_TASK_LISTS=""  # comma-separated list names; empty = all
# export CALDAV_CALENDARS=""  # comma-separated calendar names; empty = all

# RSS / Atom feed reader (required for "rss" view)
# export RSS_URLS="https://example.com/feed.xml"  # comma-separated feed URLs
# export RSS_TITLE="RSS"

# GitHub activity (required for "github" view)
# export GITHUB_USERNAME="your_username"
# export GITHUB_TOKEN=""  # personal access token; optional but recommended
